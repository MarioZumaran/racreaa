{
  "version": 2,
  "regions": ["iad1"],
  "functions": {
    "api/*.js": { "maxDuration": 30 },
    "api/auth/*.js": { "maxDuration": 30 },
    "api/tenant/*.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/frontend/dashboard.html",               "destination": "/public/dashboard.html" },
    { "source": "/frontend/login.html",                   "destination": "/public/login.html" },
    { "source": "/frontend/calificacion-alimentos.html",  "destination": "/public/calificacion-alimentos.html" },
    { "source": "/dashboard",                             "destination": "/public/dashboard.html" },
    { "source": "/login",                                 "destination": "/public/login.html" },
    { "source": "/audit",                                 "destination": "/public/calificacion-alimentos.html" }
  ]
}
