# =============================================================================
# RACREAA — Environment Variables (Producción)
# Configurar en: Vercel Dashboard > Project > Settings > Environment Variables
# NUNCA commitear este archivo. Añadir a .gitignore.
# =============================================================================

# ── BASE DE DATOS ──────────────────────────────────────────────────────────
# PostgreSQL connection string con SSL obligatorio
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://racreaa_app:PASSWORD@HOST:5432/racreaa?sslmode=require"

# Pool de conexiones (recomendado para Serverless)
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=5000

# ── AUTENTICACIÓN JWT ──────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_BYTE_HEX_SECRET"
JWT_EXPIRY="8h"
JWT_ALGORITHM="HS256"

# ── VERCEL BLOB STORAGE ────────────────────────────────────────────────────
# Obtener en: Vercel Dashboard > Storage > Blob > Create Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXXXXXXXXX"

# ── RESEND — NOTIFICACIONES TRANSACCIONALES ────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
AUDIT_REPORT_EMAIL="reportes@tudominio.com"

# ── CORS ────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS="https://racreaa.vercel.app,https://tudominio.com"

# ── RATE LIMITING ───────────────────────────────────────────────────────────
# (Implementar con @upstash/ratelimit + Upstash Redis)
UPSTASH_REDIS_REST_URL="https://XXXXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN="XXXXXXXXXXXXXXXXXXXX"
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW="1 m"

# ── MONITOREO ───────────────────────────────────────────────────────────────
SENTRY_DSN="https://XXXX@XXXX.ingest.sentry.io/XXXX"


# =============================================================================
# CAPACITOR — FLAG_SECURE (Android / iOS)
# Bloquea capturas y grabaciones de pantalla a nivel de sistema operativo
# =============================================================================
#
# INSTALACIÓN:
#   npm install @capacitor/core @capacitor/android @capacitor/ios
#   npx cap init RACREAA com.dmzkitchen.racreaa
#   npx cap add android
#   npx cap add ios
#
# ANDROID — MainActivity.java (o MainActivity.kt)
# ─────────────────────────────────────────────────
# package com.dmzkitchen.racreaa;
#
# import android.os.Bundle;
# import android.view.WindowManager;
# import com.getcapacitor.BridgeActivity;
#
# public class MainActivity extends BridgeActivity {
#   @Override
#   public void onCreate(Bundle savedInstanceState) {
#     super.onCreate(savedInstanceState);
#     // FLAG_SECURE: bloquea capturas de pantalla y grabación de pantalla
#     // También bloquea la vista previa en el selector de apps recientes
#     getWindow().setFlags(
#       WindowManager.LayoutParams.FLAG_SECURE,
#       WindowManager.LayoutParams.FLAG_SECURE
#     );
#   }
# }
#
# iOS — AppDelegate.swift
# ─────────────────────────────────────────────────
# import UIKit
# import Capacitor
#
# @UIApplicationMain
# class AppDelegate: UIResponder, UIApplicationDelegate {
#   var window: UIWindow?
#
#   func applicationWillResignActive(_ application: UIApplication) {
#     // Oscurecer la pantalla al pasar la app a segundo plano
#     // Evita que el sistema capture un thumbnail de la pantalla
#     window?.isHidden = true
#   }
#
#   func applicationDidBecomeActive(_ application: UIApplication) {
#     window?.isHidden = false
#   }
# }
#
# NOTA: iOS no tiene un equivalente directo a FLAG_SECURE de Android.
# La técnica de isHidden en applicationWillResignActive es la práctica
# recomendada por Apple para evitar que el sistema capture un snapshot
# de la interfaz al pasar a segundo plano.
# Para bloquear screenshots durante el uso activo en iOS, se requiere
# MDM (Mobile Device Management) empresarial.
#
# React Native (alternativa):
#   npm install react-native-flag-secure-android  # Android
#   import FlagSecure from 'react-native-flag-secure-android';
#   FlagSecure.activate();  // en el componente raíz


